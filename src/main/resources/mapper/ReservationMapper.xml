<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.ReservationMapper">
<select id="getAllReservations" resultType="com.example.demo.entity.Room">
	SELECT id,roomId,date,start,end,userId FROM reservation ORDER BY id
</select>

<select id="getReservationById" resultType="com.example.demo.entity.Reservation">
	SELECT id,roomId,date,start,end,userId FROM reservation WHERE id =#{id}
</select>

<insert id="insertReservation" parameterType="com.example.demo.entity.Reservation">
	INSERT INTO reservation(id,roomId,date,start,end,userId) VALUES(Null,#{roomId},#{date},#{start},#{end},#{userId})
</insert>

<update id="updateReservation" parameterType="com.example.demo.entity.Reservation">
	UPDATE reservation SET roomId=#{roomId},date=#{date},start=#{start},end=#{end},userId=#{userId} WHERE id=#{id}
</update>

<delete id="deleteReservationById" parameterType="com.example.demo.entity.Reservation">
	DELETE FROM reservation WHERE id=#{id}
</delete>

</mapper>